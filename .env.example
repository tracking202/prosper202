# ── Prosper202 Docker Environment ─────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── MySQL ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=prosper202
MYSQL_USER=prosper202
MYSQL_PASSWORD=changeme_app

# ── Ports ─────────────────────────────────────────────────
# HTTP port exposed on the host
HTTP_PORT=80
# MySQL port (bound to localhost only by default for security)
MYSQL_PORT=127.0.0.1:3306

# ── Memcached ─────────────────────────────────────────────
# Memory in MB allocated to memcached
MEMCACHED_MEMORY=256

# ── Cron ──────────────────────────────────────────────────
# Seconds between cron runs (default 60)
CRON_INTERVAL=60
